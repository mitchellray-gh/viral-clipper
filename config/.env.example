# ============================================================
# Viral Clipper Pipeline - Credentials
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ---- Google / Gemini / YouTube ----
# Get from: https://console.cloud.google.com
# Enable: YouTube Data API v3, Generative Language API
GOOGLE_API_KEY=your_gemini_api_key_here
YOUTUBE_API_KEY=your_youtube_data_api_key_here

# YouTube OAuth2 (for uploading as your channel)
# Download oauth2 client credentials JSON from Google Cloud Console
YOUTUBE_CLIENT_SECRETS_FILE=config/client_secrets.json
YOUTUBE_TOKEN_FILE=config/youtube_token.json
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxx

# ---- Reddit API ----
# Get from: https://www.reddit.com/prefs/apps -> Create App (script type)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ViralClipper/1.0 by YourRedditUsername

# ---- Optional: NewsData.io (free tier 200 req/day) ----
# Get from: https://newsdata.io (free signup)
NEWSDATA_API_KEY=

# ---- Optional: Proxy for yt-dlp (if rate limited) ----
YT_DLP_PROXY=
